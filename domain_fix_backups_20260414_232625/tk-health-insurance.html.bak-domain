    <button class="cookie-settings-btn" onclick="openModal('cookie-settings')">Settings</button>
  </div>
</div>

<div class="modal-overlay" id="modal-cookie-settings" role="dialog" aria-modal="true">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('cookie-settings')">✕</button>
    <h2>Cookie Settings</h2>
    <div class="cookie-toggle-row">
      <div class="cookie-toggle-info"><strong>Technically Necessary</strong><span>Always active.</span></div>
      <label class="toggle-switch"><input type="checkbox" checked disabled><span class="toggle-slider"></span></label>
    </div>
    <div class="cookie-toggle-row">
      <div class="cookie-toggle-info"><strong>Analytics</strong></div>
      <label class="toggle-switch"><input type="checkbox" id="toggle-analytics"><span class="toggle-slider"></span></label>
    </div>
    <div class="cookie-toggle-row">
      <div class="cookie-toggle-info"><strong>Affiliate Tracking</strong></div>
      <label class="toggle-switch"><input type="checkbox" id="toggle-affiliate"><span class="toggle-slider"></span></label>
    </div>
    <button class="cookie-save-btn" onclick="saveGranularCookies()">Save Selection</button>
  </div>
</div>

<script src="script.js"></script>
<script>
/* ── TK Calculator ── */
(function() {
  const TK_RATE = 0.1729;
  const CONTRIB_CEILING_MONTHLY = 5512.50; // 2026 Beitragsbemessungsgrenze / 12

  function calculate() {
    const rawSalary = parseFloat(document.getElementById('tk-salary')?.value) || 4000;
    const employment = document.getElementById('tk-employment')?.value || 'employee';
    const grid = document.getElementById('tk-result-grid');
    const note = document.getElementById('tk-result-note');
    if (!grid) return;

    const assessedSalary = Math.min(rawSalary, CONTRIB_CEILING_MONTHLY);
    let employeeShare, employerShare, totalContrib, noteText;

    if (employment === 'employee') {
      totalContrib = assessedSalary * TK_RATE;
      employeeShare = totalContrib / 2;
      employerShare = totalContrib / 2;
      noteText = `Your employer pays €${employerShare.toFixed(2)}/month in addition. The contribution ceiling is €5,512.50/month gross — above this, contributions do not increase. Annual total employee contribution: €${(employeeShare * 12).toFixed(0)}.`;
    } else if (employment === 'freelance') {
      totalContrib = assessedSalary * TK_RATE;
      employeeShare = totalContrib; // pays full rate
      employerShare = 0;
      noteText = `As a freelancer, you pay the full contribution rate yourself (no employer share). Minimum monthly contribution applies regardless of actual income. The minimum income floor for 2026 is approximately €1,178/month.`;
    } else if (employment === 'student') {
      const studentRate = 0.0815; // student health insurance special rate 2026
      totalContrib = 147.00; // approx flat rate for students (TK 2026 estimate)
      employeeShare = totalContrib;
      employerShare = 0;
      noteText = `Student health insurance has a flat-rate contribution not based on salary. TK student rate for 2026 is approximately €147/month including Pflegeversicherung. Available for students under 30 (or up to 14 semesters).`;
    } else {
      // mini-job
      totalContrib = 0;
      employeeShare = 0;
      employerShare = rawSalary * 0.13;
      noteText = `Mini-job employees (under €556/month) pay no health insurance contributions themselves. Your employer pays a flat 13% Pauschalabgabe to the mini-job central office.`;
    }

    const netSalary = employment === 'employee' ? rawSalary - employeeShare - (rawSalary * 0.093) - (rawSalary * 0.018) - (rawSalary * 0.013) : rawSalary; // approx after all deductions

    grid.innerHTML = `
      <div class="tk-result-item">
        <div class="tk-result-num">€${employeeShare.toFixed(0)}</div>
        <div class="tk-result-label">Your TK Share / month</div>
      </div>
      ${employerShare > 0 ? `<div class="tk-result-item">
        <div class="tk-result-num">€${employerShare.toFixed(0)}</div>
        <div class="tk-result-label">Employer Share / month</div>
      </div>` : ''}
      <div class="tk-result-item">
        <div class="tk-result-num">€${totalContrib.toFixed(0)}</div>
        <div class="tk-result-label">Total TK Contribution</div>
      </div>
      ${employment === 'employee' ? `<div class="tk-result-item">
        <div class="tk-result-num">€${(employeeShare * 12).toFixed(0)}</div>
        <div class="tk-result-label">Your Share / Year</div>
      </div>` : ''}
    `;

    if (note) note.textContent = noteText;
    document.getElementById('tk-result')?.classList.add('visible');
  }

  ['tk-salary', 'tk-employment'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', calculate);
  });

  calculate();
})();
</script>

</body>
</html>