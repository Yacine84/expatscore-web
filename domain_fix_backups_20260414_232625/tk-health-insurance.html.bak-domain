          <th>Barmer</th>
          <th>DAK</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Total Rate 2026</td>
          <td><span class="it-rate it-best">17.29%</span></td>
          <td><span class="it-rate">varies by region: 16.7–18.3%</span></td>
          <td><span class="it-rate">17.10%</span></td>
          <td><span class="it-rate">17.20%</span></td>
        </tr>
